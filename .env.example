# Jitsi Management Platform - Environment Variables Template
# Copy this file to .env and fill in actual values
# DO NOT commit .env file to version control!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DB_URL=jdbc:postgresql://localhost:5432/jmp
DB_USER=jmp
DB_PASS=your_db_password

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=localhost
REDIS_PASS=

# =============================================================================
# JWT SECURITY CONFIGURATION
# =============================================================================
# Generate secure secrets (minimum 256 bits / 32 bytes for HS256)
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# =============================================================================
# JITSI CONFIGURATION
# =============================================================================
JITSI_DOMAIN=meet.jit.si
JITSI_JWT_APP_ID=jmp-platform
JITSI_JWT_APP_SECRET=your_jitsi_jwt_secret

# =============================================================================
# OPTIONAL: Monitoring & Observability
# =============================================================================
# PROMETHEUS_ENABLED=true
# JAEGER_ENDPOINT=http://localhost:14268/api/traces